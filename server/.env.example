PORT=5000
NODE_ENV=production

# Atlas URI (use a rotated password and least-privilege DB user)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# JWT secret used to sign and verify auth tokens
JWT_SECRET=replace_with_a_long_random_secret

# Allowed frontend origins (comma-separated)
# Local + production frontend examples
CORS_ORIGINS=http://localhost:5173,https://your-frontend-app.vercel.app

# DNS override is OFF by default in production.
# Set true only if your runtime DNS cannot resolve SRV records.
ENABLE_CUSTOM_DNS=false
DNS_SERVERS=8.8.8.8,1.1.1.1

# Mongo connection behavior
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_RETRY_DELAY_MS=2000
MONGO_MAX_RETRY_DELAY_MS=30000
MONGO_CONNECT_MAX_RETRIES=10
